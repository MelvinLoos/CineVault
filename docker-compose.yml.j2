# =============================================================================
# docker-compose.yml — Prosumer Edge Media Hub
# Deployed to: /opt/mediastack/docker-compose.yml on The Host
#
# Spec references:
#   CONSTITUTION.MD     — Non-negotiable tech stack & architectural maxims
#   ARCHITECTURE.md     — Network topography, file system, resource constraints
#   PRODUCT_SPECIFICATION.md — DDD Ubiquitous Language & Bounded Contexts
#   AGENTS.md           — Zero Root Execution, State vs. Compute, Idempotency
#
# Idempotency: Docker Compose is declarative. Re-running `docker compose up -d`
# is always safe — it only creates or recreates containers whose definition
# has changed. No manual cleanup is required between runs. (AGENTS.md §3)
#
# Volume path convention: all paths are relative to this file's location
# (/opt/mediastack/). They resolve to absolute paths on The Host automatically.
# No volumes are mapped outside /opt/mediastack/ (State vs. Compute — AGENTS.md §3).
# =============================================================================

# ---------------------------------------------------------------------------
# Zero-Trust Network Micro-segmentation (ARCHITECTURE.md §2)
# Three isolated bridge networks. No service may communicate across a network
# boundary unless it is explicitly attached to both networks.
# ---------------------------------------------------------------------------
networks:
  ingress_net:
    driver: bridge
    # Boundary: cloudflared → seerr → jellyfin
    # Connects The Ingress to user-facing services only.
    # No direct path to acquisition or processing services.

  internal_api:
    driver: bridge
    # Boundary: seerr ↔ radarr ↔ sonarr
    # Scoped to Acquisition bounded-context API calls initiated by seerr.
    # Not reachable from The Ingress or The Download Client.

  acquisition_net:
    driver: bridge
    # Boundary: radarr ↔ sonarr ↔ prowlarr ↔ sabnzbd
    # Scoped to Acquisition and Processing bounded contexts.
    # The Indexer and The Download Client are isolated here.

  socket_proxy_net:
    driver: bridge
    # Boundary: homepage / watchtower → docker-proxy
    # Scoped to Docker socket abstraction for security.

# ---------------------------------------------------------------------------
# Service Definitions
# Global rules applied to ALL services (unless an explicit exception is noted):
#   - PUID / PGID: ${PUID} / ${PGID} sourced from .env
#     Canonical values: PUID=5000, PGID=5000 (mediasvc) — provision_host.yml is authoritative
#     Zero Root Execution — AGENTS.md §3, ARCHITECTURE.md §3
#   - TZ: ${TZ} sourced from .env
#   - restart: unless-stopped
#   - All volume mounts within /opt/mediastack/ (State vs. Compute — AGENTS.md §3)
# ---------------------------------------------------------------------------
services:

  # ---------------------------------------------------------------------------
  # Delivery Bounded Context (PRODUCT_SPECIFICATION.md §2)
  # Delivery context — Intel QuickSync hardware transcoding via /dev/dri/renderD128
  # ---------------------------------------------------------------------------
  jellyfin:
    image: lscr.io/linuxserver/jellyfin:latest # Changed to LSIO
    container_name: jellyfin
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
      - UMASK=002
    volumes:
      - ./appdata/jellyfin:/config
      - ./data:/data:ro
{% if host_has_quicksync %}
    devices:
      - /dev/dri/renderD128:/dev/dri/renderD128
{% endif %}
    networks:
      - ingress_net
    restart: unless-stopped
    ports:
      - "8096:8096"

  # ---------------------------------------------------------------------------
  # Acquisition Bounded Context — The Library: movies (PRODUCT_SPECIFICATION.md §2)
  # Acquisition context — manages The Library: movies. Full /data mount required for atomic hardlinks.
  # ---------------------------------------------------------------------------
  radarr:
    image: lscr.io/linuxserver/radarr:latest
    container_name: radarr
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
      - UMASK=002
    volumes:
      - ./appdata/radarr:/config
      - ./data:/data  # Full /data subtree required for atomic hardlinks between usenet/ and media/
    networks:
      - internal_api
      - acquisition_net
    restart: unless-stopped
    ports:
      - "7878:7878"

  # ---------------------------------------------------------------------------
  # Acquisition Bounded Context — The Library: tv (PRODUCT_SPECIFICATION.md §2)
  # Acquisition context — manages The Library: tv. Full /data mount required for atomic hardlinks.
  # ---------------------------------------------------------------------------
  sonarr:
    image: lscr.io/linuxserver/sonarr:latest
    container_name: sonarr
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
      - UMASK=002
    volumes:
      - ./appdata/sonarr:/config
      - ./data:/data  # Full /data subtree required for atomic hardlinks between usenet/ and media/
    networks:
      - internal_api
      - acquisition_net
    restart: unless-stopped
    ports:
      - "8989:8989"

  # ---------------------------------------------------------------------------
  # Acquisition Bounded Context — The Indexer (PRODUCT_SPECIFICATION.md §1 & §2)
  # Acquisition context — The Indexer. Bridges Usenet indexers to Radarr and Sonarr.
  # ---------------------------------------------------------------------------
  prowlarr:
    image: lscr.io/linuxserver/prowlarr:latest
    container_name: prowlarr
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
      - UMASK=002
    volumes:
      - ./appdata/prowlarr:/config
    networks:
      - acquisition_net
    restart: unless-stopped
    ports:
      - "9696:9696"

  # ---------------------------------------------------------------------------
  # Processing Bounded Context — The Download Client (PRODUCT_SPECIFICATION.md §1 & §2)
  # Processing context — The Download Client. Resource-limited to prevent host starvation during unpack.
  # ---------------------------------------------------------------------------
  sabnzbd:
    image: lscr.io/linuxserver/sabnzbd:latest
    container_name: sabnzbd
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
      - UMASK=002
    volumes:
      - ./appdata/sabnzbd:/config
      - ./data:/data
    networks:
      - acquisition_net
    # Non-negotiable resource limits — ARCHITECTURE.md §3
    # Prevents The Host from being starved during SABnzbd unpack operations.
    deploy:
      resources:
        limits:
          cpus: "2.0"
          memory: 2g
    restart: unless-stopped
    ports:
      - "8080:8080"

  # ---------------------------------------------------------------------------
  # Media Request + Identity & Access Bounded Contexts (PRODUCT_SPECIFICATION.md §2)
  # Media Request + Identity & Access contexts — the user-facing discovery and request UI.
  # ---------------------------------------------------------------------------
  seerr:
    image: fallenbagel/jellyseerr:latest
    container_name: seerr
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
      - UMASK=002
    volumes:
      - ./appdata/seerr:/app/config
    networks:
      - ingress_net
      - internal_api
    restart: unless-stopped
    ports:
      - "5055:5055"

  homepage:
    image: ghcr.io/gethomepage/homepage:latest
    container_name: homepage
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
      - "HOMEPAGE_ALLOWED_HOSTS=*"
      - HOMEPAGE_VAR_RADARR_KEY=${RADARR_API_KEY}
      - HOMEPAGE_VAR_SONARR_KEY=${SONARR_API_KEY}
      - HOMEPAGE_VAR_SABNZBD_KEY=${SABNZBD_API_KEY}
      - HOMEPAGE_VAR_PROWLARR_KEY=${PROWLARR_API_KEY}
      - UMASK=002
    ports:
      - "80:3000"
    extra_hosts:
      - "host.docker.internal:host-gateway"
    volumes:
      - ./appdata/homepage:/app/config
    networks:
      - ingress_net
      - socket_proxy_net
    restart: unless-stopped

  # ---------------------------------------------------------------------------
  # Ingress Bounded Context — The Ingress (PRODUCT_SPECIFICATION.md §1)
  # Ingress context — The Ingress. Zero-trust Cloudflare Tunnel. No port-forwarding required (CONSTITUTION.MD Maxim 4).
  # PUID/PGID intentionally omitted: cloudflared manages its own non-root internal user.
  # ---------------------------------------------------------------------------
  cloudflared:
    image: cloudflare/cloudflared:latest
    container_name: cloudflared
    profiles:
      - ingress
    command: tunnel --no-autoupdate run --token ${CLOUDFLARED_TOKEN}
    # No volumes: cloudflared is stateless compute — all tunnel state lives in Cloudflare's control plane.
    networks:
      - ingress_net
    restart: unless-stopped
    environment:
      - TUNNEL_TOKEN=${CLOUDFLARED_TOKEN}

  # ---------------------------------------------------------------------------
  # Maintenance Bounded Context (PRODUCT_SPECIFICATION.md §2)
  # Security context — Docker Socket Proxy to avoid mounting /var/run/docker.sock in user-facing/app containers.
  # ---------------------------------------------------------------------------
  docker-proxy:
    image: tecnativa/docker-socket-proxy:latest
    container_name: docker-proxy
    environment:
      - CONTAINERS=1
      - IMAGES=1
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    networks:
      - socket_proxy_net
    restart: unless-stopped

  # ---------------------------------------------------------------------------
  # Maintenance Bounded Context (PRODUCT_SPECIFICATION.md §2)
  # Maintenance context — keeps Radarr and Sonarr in sync with TRaSH Guides.
  # ---------------------------------------------------------------------------
  recyclarr:
    image: ghcr.io/recyclarr/recyclarr:latest
    container_name: recyclarr
    user: ${PUID}:${PGID}
    environment:
      - TZ=${TZ}
    volumes:
      - ./appdata/recyclarr:/config
    networks:
      - internal_api
    restart: unless-stopped
  watchtower:
    image: containrrr/watchtower
    container_name: watchtower
    environment:
      - TZ=${TZ}
      - WATCHTOWER_CLEANUP=true
      - WATCHTOWER_INCLUDE_STOPPED=true
      - WATCHTOWER_SCHEDULE=0 0 4 * * *
      - DOCKER_HOST=tcp://docker-proxy:2375
      - UMASK=002
    networks:
      - socket_proxy_net
    restart: unless-stopped
