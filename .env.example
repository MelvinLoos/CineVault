# =============================================================================
# .env.example — Prosumer Edge Media Hub environment template
#
# Copy this file to .env and populate every variable before running:
#   cp .env.example .env
#
# DDD Ubiquitous Language (PRODUCT_SPECIFICATION.md §1):
#   The Host      : The physical Intel N100 Mini-PC running Debian 13 "Trixie".
#   The Ingress   : The secure Cloudflare Tunnel connecting the outside world.
#
# Zero Root Execution (AGENTS.md §3 + ARCHITECTURE.md §3):
#   All containers run as the mediasvc service account, never as root.
#   PUID and PGID must match the mediasvc system user provisioned on The Host
#   by the Ansible playbook (ansible/playbooks/provision_host.yml).
# =============================================================================

# UID of the mediasvc system user on The Host. Canonical value defined in ansible/playbooks/provision_host.yml.
# Zero Root Execution: all containers drop privileges to this UID at startup. (AGENTS.md §3)
PUID=5000

# GID of the mediasvc system user on The Host. Canonical value defined in ansible/playbooks/provision_host.yml.
# Zero Root Execution: all containers drop privileges to this GID at startup. (AGENTS.md §3)
PGID=5000

# IANA timezone string for all containers. Example: America/New_York
# Ensures consistent log timestamps and scheduled-task execution across every service on The Host.
TZ=Europe/Amsterdam

# Authentication token for The Ingress (Cloudflare Zero Trust tunnel).
# Obtain from the Cloudflare Zero Trust dashboard under Networks > Tunnels.
# This is the sole credential that authorises cloudflared to establish The Ingress.
# CONSTITUTION.MD §2 Maxim 4: No Port Forwarding — all remote access flows through this token.
CLOUDFLARED_TOKEN=

RADARR_API_KEY=
SONARR_API_KEY=
BAZARR_API_KEY=
PROWLARR_API_KEY=

SABNZBD_API_KEY=

VPN_SERVICE_PROVIDER=
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=


# Spotweb Database Credentials
# Required for the spotweb and spotweb-db services.
SPOTWEB_DB_ROOT_PASSWORD=changeme_root
SPOTWEB_DB_NAME=spotweb
SPOTWEB_DB_USER=spotweb
SPOTWEB_DB_PASSWORD=changeme_user
