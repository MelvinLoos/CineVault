# .env.example template for the Prosumer Edge Media Hub (The Host)

# UID of mediasvc system user on The Host (see ansible/playbooks/provision_host.yml)
# This ensures Zero Root Execution for all application containers.
PUID=1001 

# GID of mediasvc system user on The Host (see ansible/playbooks/provision_host.yml)
# This ensures Zero Root Execution for all application containers.
PGID=1001

# Timezone for all containers, e.g., America/New_York
# This ensures consistent timekeeping across all services.
TZ=America/New_York

# Token for The Ingress (Cloudflare Tunnel) — obtain from Cloudflare Zero Trust dashboard
# This enables secure, zero-trust access to internal services from outside The Host.
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# Absolute path to the mediastack root on The Host
# All Docker Compose volumes will be mounted relative to this path, ensuring State vs. Compute isolation.
MEDIASTACK_ROOT=/opt/mediastack
